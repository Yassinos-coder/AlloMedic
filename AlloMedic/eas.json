{
  "cli": {
    "version": ">= 5.9.3"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "development",
        "artifactType": "apk"
      },
      "ios": {
        "buildType": "development",
        "artifactType": "ipa"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "preview",
        "artifactType": "apk"
      },
      "ios": {
        "buildType": "preview",
        "artifactType": "ipa"
      }
    },
    "production": {
      "android": {
        "buildType": "release",
        "artifactType": "apk"
      },
      "ios": {
        "buildType": "release",
        "artifactType": "ipa"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "store": "play-store",
        "track": "internal"
      }
    }
  }
}
